  "dependencies": {
    "@prisma/client": "^5.22.0",
    "fastify": "^5.8.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
